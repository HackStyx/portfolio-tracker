# Backend Environment Variables
# ================================

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Finnhub API Key
FINNHUB_API_KEY=your_finnhub_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
# Privileged server key — use ONE of: new Secret key (sb_secret_...) OR legacy service_role JWT
SUPABASE_KEY=your_supabase_secret_or_service_role_key
# Public key for verifying user JWTs in auth middleware (Dashboard → API: publishable or anon eyJ...)
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Legacy alias (optional if you use eyJ... anon instead of sb_publishable_)
# SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Optional: JWT Secret (Settings → API → JWT Settings). Enables HS256 token verify if GoTrue fails.
# SUPABASE_JWT_SECRET=your-jwt-secret
