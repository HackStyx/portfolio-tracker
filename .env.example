# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT_REF/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# NEW FORMAT: Supabase now uses publishable keys (starts with sb_publishable_)
# If your project uses the old format, use VITE_SUPABASE_ANON_KEY instead (starts with eyJ)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Backend API Configuration
VITE_API_BASE_URL=https://portfolio-tracker-backend-eh7r.onrender.com/api

# Note: For local development, use:
# VITE_API_BASE_URL=http://localhost:5000/api 