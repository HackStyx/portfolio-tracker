# Frontend Production Environment Variables
# =============================================
# Use these as a template for production deployment on Vercel
# Copy these variable names to Vercel → Project Settings → Environment Variables

# Supabase Configuration (from https://app.supabase.com/project/YOUR_PROJECT/settings/api)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Backend API Configuration
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# ⚠️ SECURITY NOTES:
# 1. NEVER commit the actual .env.production file - it's ignored by git
# 2. Set these values directly in Vercel dashboard
# 3. The PUBLISHABLE_KEY is safe for browser exposure
